if command -v omarchy-version >/dev/null 2>&1; then
  source "$HOME/.local/share/omarchy/default/bash/rc"
else
  # Activate mise before interactive check so it works in new tmux panes
  if command -v mise >/dev/null 2>&1; then
    eval "$(mise hook-env -s bash)"
  fi

  [[ $- != *i* ]] && return

  export DISABLE_SPRING=1
  export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

  if [ -f "${HOME}/.config/bash/env" ]; then
    source "${HOME}/.config/bash/env"
  fi

  if [ -f "$HOME/.config/bash/aliases" ]; then
    source "$HOME/.config/bash/aliases"
  fi

  if [ -f "$HOME/.config/bash/functions" ]; then
    source "$HOME/.config/bash/functions"
  fi

  if [ -f "$HOME/.orbstack/shell/init.bash" ]; then
    source "$HOME/.orbstack/shell/init.bash"
  fi
fi
